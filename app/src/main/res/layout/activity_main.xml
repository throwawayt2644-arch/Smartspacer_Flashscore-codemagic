<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#0F111A">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <!-- App Header Section -->
        <LinearLayout
            android:id="@+id/headerLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/soccer"
                app:tint="#6C5CE7" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="FlashScore Tracker"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Smartspacer Live Notification Extractor"
                    android:textColor="#A0A5B5"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Permission Access Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/permissionCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeColor="#252A41"
            app:strokeWidth="1dp"
            app:cardBackgroundColor="#171A2E"
            app:layout_constraintTop_toBottomOf="@id/headerLayout">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Service Status"
                        android:textColor="#A0A5B5"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/textPermissionStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="Checking..."
                        android:textColor="#FF9F43"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </RelativeLayout>

                <TextView
                    android:id="@+id/textPermissionDesc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Notification Access is required to automatically capture FlashScore live scores and goal scorers."
                    android:textColor="#E0E4F0"
                    android:textSize="13sp" />

                <Button
                    android:id="@+id/btnGrantPermission"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Grant Access"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:backgroundTint="#6C5CE7"
                    app:cornerRadius="8dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Live Match Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/matchCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeColor="#2E3558"
            app:strokeWidth="1.5dp"
            app:cardBackgroundColor="#131627"
            app:layout_constraintTop_toBottomOf="@id/permissionCard">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:gravity="center_horizontal">

                <!-- Match Status Badge -->
                <TextView
                    android:id="@+id/textMatchStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="NO ACTIVE MATCH"
                    android:textColor="#A0A5B5"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:background="#1B1E36"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="4dp" />

                <!-- Teams and Scores Layout -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginTop="16dp">

                    <!-- Home Team -->
                    <TextView
                        android:id="@+id/textHomeTeam"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Home Team"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:gravity="center" />

                    <!-- Scores -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:paddingHorizontal="16dp">

                        <TextView
                            android:id="@+id/textHomeScore"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="#FFFFFF"
                            android:textSize="44sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=" - "
                            android:textColor="#6C728A"
                            android:textSize="32sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/textAwayScore"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="#FFFFFF"
                            android:textSize="44sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Away Team -->
                    <TextView
                        android:id="@+id/textAwayTeam"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Away Team"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:gravity="center" />
                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#22273F"
                    android:layout_marginVertical="20dp" />

                <!-- Scorers Label -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="GOAL SCORERS"
                    android:textColor="#6C728A"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <!-- Scorers List -->
                <TextView
                    android:id="@+id/textScorers"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No goal scorers yet"
                    android:textColor="#E0E4F0"
                    android:textSize="14sp"
                    android:lineSpacingExtra="4dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Test Simulator Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/simulatorCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeColor="#252A41"
            app:strokeWidth="1dp"
            app:cardBackgroundColor="#171A2E"
            app:layout_constraintTop_toBottomOf="@id/matchCard"
            app:layout_constraintBottom_toBottomOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Match Simulator (Test Suite)"
                    android:textColor="#6C5CE7"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="2"
                    android:rowCount="3"
                    android:useDefaultMargins="true"
                    android:alignmentMode="alignBounds">

                    <Button
                        android:id="@+id/btnSimStart"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:text="Start Match"
                        android:textSize="12sp"
                        android:textAllCaps="false"
                        android:backgroundTint="#2E3558"
                        android:textColor="#FFFFFF" />

                    <Button
                        android:id="@+id/btnSimHomeGoal"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:text="Goal: Home Team"
                        android:textSize="12sp"
                        android:textAllCaps="false"
                        android:backgroundTint="#2E3558"
                        android:textColor="#FFFFFF" />

                    <Button
                        android:id="@+id/btnSimAwayGoal"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:text="Goal: Away Team"
                        android:textSize="12sp"
                        android:textAllCaps="false"
                        android:backgroundTint="#2E3558"
                        android:textColor="#FFFFFF" />

                    <Button
                        android:id="@+id/btnSimHalf"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:text="Half-Time"
                        android:textSize="12sp"
                        android:textAllCaps="false"
                        android:backgroundTint="#2E3558"
                        android:textColor="#FFFFFF" />

                    <Button
                        android:id="@+id/btnSimFull"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:text="Full-Time"
                        android:textSize="12sp"
                        android:textAllCaps="false"
                        android:backgroundTint="#2E3558"
                        android:textColor="#FFFFFF" />

                    <Button
                        android:id="@+id/btnSimReset"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:text="Clear State"
                        android:textSize="12sp"
                        android:textAllCaps="false"
                        android:backgroundTint="#E84118"
                        android:textColor="#FFFFFF" />
                </GridLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
