<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Permission to post notifications if needed -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    
    <!-- Permission to restart service on boot -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.SmartspacerSofascore">

        <!-- MainActivity launcher -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.SmartspacerSofascore">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- FlashScore Notification Listener Service -->
        <service
            android:name=".FlashScoreNotificationService"
            android:label="FlashScore Score Extractor"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE"
            android:exported="true">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
            </intent-filter>
        </service>

        <!-- Smartspacer Target Provider (ContentProvider) -->
        <provider
            android:name=".Target"
            android:authorities="com.meilluer.smartspacersofascore.Target"
            android:exported="true"
            android:permission="com.kieronquinn.app.smartspacer.permission.PROVIDER">
            <intent-filter>
                <action android:name="com.kieronquinn.app.smartspacer.action.TARGET_PROVIDER" />
            </intent-filter>
        </provider>

    </application>

</manifest>